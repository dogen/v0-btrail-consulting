# Copy to .env.local and fill in. Never commit real values.

# Neon Postgres connection string (Dashboard -> Connection Details, pooled)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# Shared password for the client portal login
PORTAL_PASSWORD="change-me"

# Random secret used to sign the portal session cookie (e.g. `openssl rand -hex 32`)
AUTH_SECRET="change-me"
